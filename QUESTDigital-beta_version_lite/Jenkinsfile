pipeline {
    agent any
     stages {
         stage('Clone') {
            steps {
                echo 'Cloning repository...'
            }
         }
        stage('Build'){
            steps {
                echo 'Running python file'
                bat 'python  stefie.py'
            }
        }
        stage('Test'){
            steps {
                echo 'Testing the code'
            }
        }
        stage('Deploy'){
            steps{
                echo 'Deploying to server'
            }
        }
    }
}